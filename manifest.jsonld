{
  "@context": {
    "@vocab": "https://etzhayyim.com/ns/actor#",
    "id": "@id",
    "type": "@type"
  },
  "id": "actor:hinagata",
  "type": "Actor",
  "name": "hinagata",
  "glyph": "雛形",
  "purpose": "Legal-document-template commons (法律文書雛形) — weaves fair, neutral, openly-licensed legal-document templates (contracts / agreements / covenants), decomposed into reusable clauses, into the kotoba Datom log, and binds every clause to the ACTUAL public statute it cites or is mandated by (:cites-statute / :mandated-by 縁). Surfaces integrated statutory groundedness over a template, routed to PUBLIC RELEASE (anyone may use it freely), and executes contracts electronically via the existing esign substrate. NEVER the practice of law: no advice, no opinion on a matter, no enforceability certification.",
  "status": "R1-template-commons-publishable",
  "tier": "B",
  "adr": "2606111954",
  "dependsOnAdr": ["2605262700", "2605262800", "2605231230", "2605231525", "2605181100", "2605312345", "2605215000", "2606101000"],
  "schema": ["00-contracts/schemas/legal-template-ontology.kotoba.edn"],
  "lexicons": [
    "com.etzhayyim.hinagata.template",
    "com.etzhayyim.hinagata.clause",
    "com.etzhayyim.hinagata.statuteCitation",
    "com.etzhayyim.esign.envelope",
    "com.etzhayyim.esign.signature",
    "com.etzhayyim.esign.completedEvent"
  ],
  "substrate": {
    "state": "kotoba Datom log (ADR-2605312345) — methods/datom_emit.py emits canonical EAVT (template↔clause↔statute graph as durable state)",
    "publish": "methods/publish.py — content-addresses every template body to a kotoba IPFS CIDv1 (raw/sha2-256, ipfs-parity verified) + snapshots bodies + manifest into 80-data/legal-templates; G7 outward (IPFS pin / IPNS = operator add-on)",
    "esign": "methods/esign.py — renders a template to a contract body + builds an UNSIGNED com.etzhayyim.esign.envelope; member signs client-side with WebAuthn passkey (no-server-key, ADR-2605231525)",
    "contentAddress": "methods/cid.py — kotoba IPFS CIDv1 raw (ADR-2605231525 / 2606014500 verify.mjs parity; byte-identical to `ipfs add --cid-version=1 --raw-leaves`)",
    "inference": "Murakumo-only (ADR-2605215000)",
    "runtime": "kotoba pywasm actor (componentize-py) — pure-stdlib methods, no numpy; publish/ingest runs operator/mesh-side, not in-browser WASM"
  },
  "integrates": ["actor:chigiri", "actor:musubi", "actor:shomei", "actor:warifu"],
  "lineage": "fairness/access sibling of the legal lineage — chigiri 契 runs the legal-PROCEDURE substrate (ADR-2605262700), the global legal-corpus ingests the STATUTES (ADR-2605262800); hinagata holds the published, fair, reusable DOCUMENT TEMPLATES and binds each clause to the actual statute it rests on. Same KG-mirror architecture as rasen/inochi (edge-primary, aggregate-first, non-adjudicating), specialised to legal documents.",
  "cells": [
    {
      "id": "cell:hinagata.analyze",
      "method": "methods/analyze.py",
      "input": "data/seed-legal-template-graph.kotoba.edn",
      "output": ["out/groundedness-report.md"],
      "pipeline": "load-edn → edge-primary integral (template groundedness = Σ incident clause :cites-statute/:mandated-by + direct :cites-statute × disclosed optionality weight) → clause reusability + statute pull + jurisdictional reach, aggregate-first",
      "doc": "edge-primary statutory-groundedness; publish-readiness map, never legal advice"
    },
    {
      "id": "cell:hinagata.datom-emit",
      "method": "methods/datom_emit.py",
      "input": "data/seed-legal-template-graph.kotoba.edn",
      "output": ["out/legal-template-datoms.kotoba.edn"],
      "pipeline": "ground EAVT datoms [e a v tx :add] (durable; incl. every clause↔statute binding) + derived readouts flagged :bond/is-transient (computed on read, N1/G2)",
      "doc": "kotoba Datom-log projection — first-class canonical state (ADR-2605312345)"
    },
    {
      "id": "cell:hinagata.coverage",
      "method": "methods/coverage_report.py",
      "input": "data/seed-legal-template-graph.kotoba.edn",
      "output": ["out/coverage-report.md"],
      "pipeline": "denominator (concepts/jurisdictions) + legal-system + clause-role + citation-force + statute-binding integrity (which clauses are unbound) → gap map",
      "doc": "honest coverage (all-families ~0 by design); names thin/missing buckets + the next-wave binding worklist (G5)"
    },
    {
      "id": "cell:hinagata.esign",
      "method": "methods/esign.py",
      "input": "data/seed-legal-template-graph.kotoba.edn",
      "output": ["out/contract-<template>.md", "out/envelope-<template>.json"],
      "pipeline": "render template → contract body (carries statutory provenance) → content-address (CIDv1 + SHA-256) → build UNSIGNED com.etzhayyim.esign.envelope → verify_signature (roster + anti-tamper) → check_completion → com.etzhayyim.esign.completedEvent",
      "doc": "electronic-contract bridge; member signs client-side with WebAuthn (no-server-key, ADR-2605231525)"
    },
    {
      "id": "cell:hinagata.publish",
      "method": "methods/publish.py",
      "input": "data/seed-legal-template-graph.kotoba.edn",
      "output": ["80-data/legal-templates/bodies/<template>.md", "80-data/legal-templates/PUBLISH.md", "80-data/legal-templates/publish-manifest.json"],
      "pipeline": "render every template → content-address each body (CIDv1 raw) → manifest (CID + license + jurisdiction + statute citations per template) → snapshot into 80-data/legal-templates (git-tracked, no git-lfs)",
      "doc": "OUTWARD-GATED (G7) publish to the public commons; PUBLIC openly-licensed templates, safe by construction (G1); anyone may fetch + verify CID + reuse",
      "gated": "G7 — operator/mesh-side (IPFS pin / IPNS publish)"
    }
  ],
  "wasm": {
    "status": "build-ready",
    "world": "etzhayyim:hinagata/hinagata-actor@0.1.0",
    "wit": "wasm/wit/world.wit",
    "entry": "wasm/app.py",
    "exports": ["analyze", "datoms", "coverage", "envelope"],
    "build": "wasm/build.sh (componentize-py → CID → DID-doc EtzhayyimWasmComponent service; ADR-2606014500/2606014600)",
    "note": "export bodies runnable in dev + CI-covered (tests/test_wasm.py); the componentize-py build is the operator step; G1 + no-server-key hold in WASM (the `envelope` export builds an UNSIGNED record only; embeds bounded PUBLIC seed)"
  },
  "gates": {
    "G1": "a COMMONS of fair, openly-licensed templates ANYONE may use, NEVER the practice of law — no advice, no opinion on a matter, no representation, no enforceability certification; the unit is ALWAYS a template / clause / statute-link, never a party / matter / recommendation; UPL structurally excluded (shared boundary with chigiri G14)",
    "G2": "edge-primary (N1) — statutory grounding lives only on :en/binding-load × disclosed :clause/optionality; template groundedness is the integral computed on read; no :lt/score-of-template",
    "G3": "non-adjudicating (N3) — statute citations, instrument names, optionality categories are DISCLOSED facts sourced from the public instrument / its official guidance, never hinagata verdicts; never certifies validity, sufficiency or enforceability",
    "G4": "public venue + open license — Apache-2.0 + Charter Rider; every template body content-addressed (CIDv1 raw, ipfs-parity) and free to copy + adapt; never a paywalled forms vendor",
    "G5": "sourcing honesty — every record :authoritative | :representative; statutes carry a public official source URL; coverage of all families / all jurisdictions ~0 by design; unbound clauses surfaced, not hidden",
    "G6": "Murakumo-only narration (ADR-2605215000)",
    "G7": "outward-gated — live legal-corpus binding (ADR-2605262800 statutes) + scope expansion + IPFS pin/IPNS publish requires Council + operator DID; R0/R1 = analyzer + schema + seed + content-addressed publish snapshot",
    "G8": "no-server-key (ADR-2605231525) — hinagata holds NO signing key; esign builds UNSIGNED envelopes + verifies structure only; the member signs client-side with their own WebAuthn passkey / wallet"
  }
}
